{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fowan.example/protocol/ai/v0.1/jsonrpc.schema.json",
  "title": "Fowan AI JSON-RPC v0.1",
  "oneOf": [
    { "$ref": "#/$defs/request" },
    { "$ref": "#/$defs/result" },
    { "$ref": "#/$defs/error" },
    { "$ref": "#/$defs/notification" }
  ],
  "$defs": {
    "id": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
    "request": {
      "type": "object",
      "required": ["jsonrpc", "id", "method", "params"],
      "additionalProperties": false,
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "id": { "$ref": "#/$defs/id" },
        "method": { "type": "string", "minLength": 1 },
        "params": { "type": "object" }
      }
    },
    "result": {
      "type": "object",
      "required": ["jsonrpc", "id", "result"],
      "additionalProperties": false,
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "id": { "$ref": "#/$defs/id" },
        "result": {}
      }
    },
    "error": {
      "type": "object",
      "required": ["jsonrpc", "id", "error"],
      "additionalProperties": false,
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "id": { "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] },
        "error": {
          "type": "object",
          "required": ["code", "message"],
          "additionalProperties": false,
          "properties": {
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string" },
            "data": { "type": "object" }
          }
        }
      }
    },
    "notification": {
      "type": "object",
      "required": ["jsonrpc", "method", "params"],
      "additionalProperties": false,
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "method": { "type": "string", "minLength": 1 },
        "params": { "type": "object" }
      }
    }
  }
}
