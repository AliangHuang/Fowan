{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "jsonrpc",
    "id",
    "result"
  ],
  "additionalProperties": false,
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "result": {
      "$ref": "#/$defs/channelsResult"
    }
  },
  "$defs": {
    "id": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2147483647
    },
    "channelsResult": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/channel"
      }
    },
    "channel": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "displayName",
        "defaultBaseUrl",
        "builtIn",
        "enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "defaultBaseUrl": {
          "type": "string"
        },
        "builtIn": {
          "type": "boolean"
        },
        "enabled": {
          "type": "boolean"
        }
      }
    }
  }
}
