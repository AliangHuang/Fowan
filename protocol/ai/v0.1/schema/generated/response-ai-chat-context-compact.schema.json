{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "jsonrpc",
    "id",
    "result"
  ],
  "additionalProperties": false,
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "result": {
      "$ref": "#/$defs/compactInvocationResult"
    }
  },
  "$defs": {
    "id": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2147483647
    },
    "compactInvocationResult": {
      "type": "object",
      "required": [
        "invocationId",
        "conversationId"
      ],
      "additionalProperties": false,
      "properties": {
        "invocationId": {
          "type": "string"
        },
        "conversationId": {
          "type": "string"
        }
      }
    }
  }
}
