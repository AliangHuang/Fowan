{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "jsonrpc",
    "id",
    "result"
  ],
  "additionalProperties": false,
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "result": {
      "$ref": "#/$defs/credentialsResult"
    }
  },
  "$defs": {
    "id": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2147483647
    },
    "credentialsResult": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/credential"
      }
    },
    "credential": {
      "type": "object",
      "required": [
        "id",
        "channelId",
        "label",
        "baseUrl",
        "secretHint",
        "enabled",
        "lastTestStatus",
        "lastTestAt",
        "createdAt",
        "updatedAt"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "channelId": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "baseUrl": {
          "type": "string"
        },
        "secretHint": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "lastTestStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "lastTestAt": {
          "type": [
            "string",
            "null"
          ]
        },
        "createdAt": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        }
      }
    }
  }
}
