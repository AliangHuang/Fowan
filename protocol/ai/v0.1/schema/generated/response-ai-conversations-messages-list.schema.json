{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "jsonrpc",
    "id",
    "result"
  ],
  "additionalProperties": false,
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "result": {
      "$ref": "#/$defs/messagesPageResult"
    }
  },
  "$defs": {
    "id": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2147483647
    },
    "messagesPageResult": {
      "type": "object",
      "required": [
        "conversationId",
        "activeLeafMessageId",
        "items",
        "nextCursor",
        "hasMore",
        "summary"
      ],
      "additionalProperties": false,
      "properties": {
        "conversationId": {
          "type": "string"
        },
        "activeLeafMessageId": {
          "type": [
            "string",
            "null"
          ]
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/chatMessage"
          }
        },
        "nextCursor": {
          "type": [
            "string",
            "null"
          ]
        },
        "hasMore": {
          "type": "boolean"
        },
        "summary": {
          "oneOf": [
            {
              "$ref": "#/$defs/summaryRecord"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "chatMessage": {
      "type": "object",
      "required": [
        "id",
        "role",
        "content",
        "status",
        "parentMessageId",
        "variantIndex",
        "channelName",
        "credentialName",
        "modelId",
        "createdAt"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "role": {
          "enum": [
            "user",
            "assistant"
          ]
        },
        "content": {
          "type": "string"
        },
        "status": {
          "enum": [
            "streaming",
            "completed",
            "cancelled",
            "failed"
          ]
        },
        "parentMessageId": {
          "type": [
            "string",
            "null"
          ]
        },
        "variantIndex": {
          "type": "integer",
          "minimum": 0
        },
        "channelName": {
          "type": [
            "string",
            "null"
          ]
        },
        "credentialName": {
          "type": [
            "string",
            "null"
          ]
        },
        "modelId": {
          "type": [
            "string",
            "null"
          ]
        },
        "createdAt": {
          "type": "string"
        }
      }
    },
    "summaryRecord": {
      "type": "object",
      "required": [
        "id",
        "content",
        "throughMessageId",
        "createdAt"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "throughMessageId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      }
    }
  }
}
