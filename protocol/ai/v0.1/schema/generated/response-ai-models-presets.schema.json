{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "jsonrpc",
    "id",
    "result"
  ],
  "additionalProperties": false,
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "result": {
      "$ref": "#/$defs/presetsResult"
    }
  },
  "$defs": {
    "id": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2147483647
    },
    "presetsResult": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/presetModel"
      }
    },
    "presetModel": {
      "type": "object",
      "required": [
        "channelId",
        "modelId",
        "displayName"
      ],
      "additionalProperties": false,
      "properties": {
        "channelId": {
          "type": "string"
        },
        "modelId": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        }
      }
    }
  }
}
