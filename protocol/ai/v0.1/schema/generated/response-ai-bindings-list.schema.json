{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "jsonrpc",
    "id",
    "result"
  ],
  "additionalProperties": false,
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "result": {
      "$ref": "#/$defs/bindingsResult"
    }
  },
  "$defs": {
    "id": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2147483647
    },
    "bindingsResult": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/binding"
      }
    },
    "binding": {
      "type": "object",
      "required": [
        "featureId",
        "credentialId",
        "modelProfileId",
        "updatedAt"
      ],
      "additionalProperties": false,
      "properties": {
        "featureId": {
          "const": "ai.chat"
        },
        "credentialId": {
          "type": "string"
        },
        "modelProfileId": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        }
      }
    }
  }
}
