{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "jsonrpc",
    "id",
    "result"
  ],
  "additionalProperties": false,
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "result": {
      "$ref": "#/$defs/modelsResult"
    }
  },
  "$defs": {
    "id": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2147483647
    },
    "modelsResult": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/model"
      }
    },
    "model": {
      "type": "object",
      "required": [
        "id",
        "credentialId",
        "modelId",
        "displayName",
        "source",
        "enabled",
        "lastTestStatus",
        "lastTestAt",
        "createdAt",
        "updatedAt"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "credentialId": {
          "type": "string"
        },
        "modelId": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "lastTestStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "lastTestAt": {
          "type": [
            "string",
            "null"
          ]
        },
        "createdAt": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        }
      }
    }
  }
}
