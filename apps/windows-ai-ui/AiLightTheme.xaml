<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AiPageColor">#FFF8FAFD</Color>
    <Color x:Key="AiSidebarColor">#FFF6F9FD</Color>
    <Color x:Key="AiCardColor">#FFFFFFFF</Color>
    <Color x:Key="AiPrimaryColor">#FF0B67F6</Color>
    <Color x:Key="AiPrimaryHoverColor">#FF075CE0</Color>
    <Color x:Key="AiSelectionColor">#FFEAF3FF</Color>
    <Color x:Key="AiBorderColor">#FFD9E1EC</Color>
    <Color x:Key="AiTextColor">#FF171C26</Color>
    <Color x:Key="AiSecondaryTextColor">#FF697386</Color>
    <Color x:Key="AiMutedTextColor">#FF8A93A2</Color>
    <Color x:Key="AiSuccessColor">#FF16A34A</Color>
    <Color x:Key="AiDangerColor">#FFEF333F</Color>
    <SolidColorBrush x:Key="AiPageBrush" Color="{StaticResource AiPageColor}" />
    <SolidColorBrush x:Key="AiSidebarBrush" Color="{StaticResource AiSidebarColor}" />
    <SolidColorBrush x:Key="AiCardBrush" Color="{StaticResource AiCardColor}" />
    <SolidColorBrush x:Key="AiPrimaryBrush" Color="{StaticResource AiPrimaryColor}" />
    <SolidColorBrush x:Key="AiPrimaryHoverBrush" Color="{StaticResource AiPrimaryHoverColor}" />
    <SolidColorBrush x:Key="AiSelectionBrush" Color="{StaticResource AiSelectionColor}" />
    <SolidColorBrush x:Key="AiBorderBrush" Color="{StaticResource AiBorderColor}" />
    <SolidColorBrush x:Key="AiTextBrush" Color="{StaticResource AiTextColor}" />
    <SolidColorBrush x:Key="AiSecondaryTextBrush" Color="{StaticResource AiSecondaryTextColor}" />
    <SolidColorBrush x:Key="AiMutedTextBrush" Color="{StaticResource AiMutedTextColor}" />
    <SolidColorBrush x:Key="AiSuccessBrush" Color="{StaticResource AiSuccessColor}" />
    <SolidColorBrush x:Key="AiDangerBrush" Color="{StaticResource AiDangerColor}" />

    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Foreground" Value="{StaticResource AiTextBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style x:Key="AiTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="25" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AiTextBrush}" />
    </Style>
    <Style x:Key="AiBodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{StaticResource AiSecondaryTextBrush}" />
    </Style>
    <Style x:Key="AiButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="44" />
        <Setter Property="MinWidth" Value="44" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{StaticResource AiTextBrush}" />
        <Setter Property="Background" Value="{StaticResource AiCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AiBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style x:Key="AiPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AiButtonStyle}">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource AiPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AiPrimaryBrush}" />
    </Style>
    <Style x:Key="AiOutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource AiButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource AiPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AiPrimaryBrush}" />
    </Style>
    <Style x:Key="AiNavButtonStyle" TargetType="Button" BasedOn="{StaticResource AiButtonStyle}">
        <Setter Property="Height" Value="58" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="18,0" />
    </Style>
    <Style x:Key="AiTextBoxStyle" TargetType="TextBox">
        <Setter Property="Height" Value="42" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{StaticResource AiTextBrush}" />
        <Setter Property="Background" Value="{StaticResource AiCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AiBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,0" />
    </Style>
    <Style x:Key="AiComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Height" Value="44" />
        <Setter Property="MinWidth" Value="200" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{StaticResource AiTextBrush}" />
        <Setter Property="Background" Value="{StaticResource AiCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AiBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style x:Key="AiListViewStyle" TargetType="ListView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>
</ResourceDictionary>
