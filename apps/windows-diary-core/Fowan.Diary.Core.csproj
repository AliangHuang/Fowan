<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>$(FowanTargetFramework)</TargetFramework>
    <RootNamespace>Fowan.Diary.Core</RootNamespace>
    <AssemblyName>Fowan.Diary.Core</AssemblyName>
    <FowanDiaryOutputConfiguration Condition="'$(Configuration)' == 'Release'">release</FowanDiaryOutputConfiguration>
    <FowanDiaryOutputConfiguration Condition="'$(Configuration)' != 'Release'">debug</FowanDiaryOutputConfiguration>
    <OutputPath>..\..\out\windows-diary\$(FowanDiaryOutputConfiguration)\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\windows-todo-core\Fowan.Todo.Core.csproj" />
  </ItemGroup>
</Project>
